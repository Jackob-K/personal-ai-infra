OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3:8b
OLLAMA_URL=http://localhost:11434
GOOGLE_MAPS_API_KEY=
PLANNER_CONFIG_PATH=data/planner_config.json

# CalDAV (Apple Calendar / iCloud CalDAV)
CALDAV_CALENDAR_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
